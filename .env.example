# Required for the audit harness (auditor + judge + target LLMs).
OPENAI_API_KEY=your-openai-api-key

# Optional: any OpenAI-compatible Responses API proxy.
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional default model for auditor/target/judge when --model is omitted.
# Same as the CLI default if unset.
MOCK_DEFAULT_MODEL=gpt-5-nano
