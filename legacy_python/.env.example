# Copy to .env and fill in. The app runs without an API key in "offline mock" mode.

# OpenAI-compatible API (used for tester + judge).
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Models. The spec calls for "gpt-5-nano". Override to whatever you have access to.
TESTER_MODEL=gpt-4o-mini
JUDGE_MODEL=gpt-4o-mini
TARGET_AGENT_MODEL=gpt-4o-mini

# Cost guardrails
MAX_LLM_CALLS_PER_TEST=60
MAX_CONCURRENT_TESTS=2

# MCTS hyperparameters (overridable via UI)
MCTS_MAX_ITERATIONS=20
MCTS_MAX_DEPTH=6
MCTS_BRANCHING=3
MCTS_UCB_C=1.41
MCTS_NEAR_MISS_BONUS=0.35
